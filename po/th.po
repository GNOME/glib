#: gio/gappinfo.c:374
msgid "Setting default applications not supported yet"
msgstr "ยังไม่รองรับการกำหนดแอปพลิเคชันเริ่มต้น"

#: gio/gappinfo.c:406
msgid "Setting application as last used for type not supported yet"
msgstr "ยังไม่รองรับการกำหนดแอปพลิเคชันเป็นแอปที่ใช้ล่าสุดสำหรับชนิด"

#: gio/gappinfo.c:994
#, c-format
msgid "Failed to find default application for content type ‘%s’"
msgstr "ไม่พบแอปพลิเคชันเริ่มต้นสำหรับชนิดเนื้อหา ‘%s’"

#: gio/gappinfo.c:1056
#, c-format
msgid "Failed to find default application for URI Scheme ‘%s’"
msgstr "ไม่พบแอปพลิเคชันเริ่มต้นสำหรับ URI Scheme ‘%s’"

#: gio/gapplication.c:507
msgid "GApplication Options:"
msgstr "ตัวเลือกของ GApplication:"

#: gio/gapplication.c:507
msgid "Show GApplication options"
msgstr "แสดงตัวเลือกของ GApplication"

#: gio/gapplication.c:552
msgid "Enter GApplication service mode (use from D-Bus service files)"
msgstr "เข้าสู่โหมดบริการ GApplication (ใช้จากไฟล์บริการ D-Bus)"

#: gio/gapplication.c:564
msgid "Override the application’s ID"
msgstr "กำหนดค่าทับ ID ของแอปพลิเคชัน"

#: gio/gapplication.c:575
msgid "Print the application version"
msgstr "แสดงเวอร์ชันของแอปพลิเคชัน"

#: gio/gapplication.c:587
msgid "Replace the running instance"
msgstr "แทนที่อินสแตนซ์ที่ทำงานอยู่"

#: gio/gapplication-tool.c:47 gio/gapplication-tool.c:48 gio/gio-tool.c:230 gio/gresource-tool.c:497 gio/gsettings-tool.c:593
msgid "Print help"
msgstr "แสดงวิธีใช้"

#: gio/gapplication-tool.c:49 gio/gresource-tool.c:498 gio/gresource-tool.c:566
msgid "[COMMAND]"
msgstr "[คำสั่ง]"

#: gio/gapplication-tool.c:51 gio/gio-tool.c:231
msgid "Print version"
msgstr "แสดงเวอร์ชัน"

#: gio/gapplication-tool.c:52 gio/gsettings-tool.c:599
msgid "Print version information and exit"
msgstr "แสดงข้อมูลเวอร์ชันแล้วจบการทำงาน"

#: gio/gapplication-tool.c:55
msgid "List applications"
msgstr "แสดงรายชื่อแอปพลิเคชัน"

#: gio/gapplication-tool.c:56
msgid "List the installed D-Bus activatable applications (by .desktop files)"
msgstr "แสดงรายชื่อของแอปพลิเคชันที่สามารถเรียกผ่าน D-Bus (โดยใช้ไฟล์ .desktop) ที่ติดตั้งไว้"

#: gio/gapplication-tool.c:59
msgid "Launch an application"
msgstr "เรียกแอปพลิเคชันทำงาน"

#: gio/gapplication-tool.c:60
msgid "Launch the application (with optional files to open)"
msgstr "เรียกแอปพลิเคชันทำงาน (โดยอาจระบุไฟล์ที่จะเปิดด้วยก็ได้)"

#: gio/gapplication-tool.c:61
msgid "APPID [FILE…]"
msgstr "APPID [ไฟล์…]"

#: gio/gapplication-tool.c:63
msgid "Activate an action"
msgstr "เรียกการกระทำ"

#: gio/gapplication-tool.c:64
msgid "Invoke an action on the application"
msgstr "เรียกการกระทำกับตัวแอปพลิเคชัน"

#: gio/gapplication-tool.c:65
msgid "APPID ACTION [PARAMETER]"
msgstr "APPID การกระทำ [พารามิเตอร์]"

#: gio/gapplication-tool.c:67
msgid "List available actions"
msgstr "แสดงรายชื่อการกระทำที่ใช้ได้"

#: gio/gapplication-tool.c:68
msgid "List static actions for an application (from .desktop file)"
msgstr "แสดงรายชื่อการกระทำที่ตายตัวสำหรับแอปพลิเคชันหนึ่ง ๆ (จากไฟล์ .desktop)"

#: gio/gapplication-tool.c:69 gio/gapplication-tool.c:75
msgid "APPID"
msgstr "APPID"

#: gio/gapplication-tool.c:74 gio/gapplication-tool.c:137 gio/gdbus-tool.c:110 gio/gio-tool.c:259 gio/glib-compile-resources.c:843
msgid "COMMAND"
msgstr "คำสั่ง"

#: gio/gapplication-tool.c:74
msgid "The command to print detailed help for"
msgstr "คำสั่งที่ต้องการแสดงรายละเอียดวิธีใช้"

#: gio/gapplication-tool.c:75
msgid "Application identifier in D-Bus format (eg: org.example.viewer)"
msgstr "ตัวระบุของแอปพลิเคชันในรูปแบบของ D-Bus (เช่น: org.example.viewer)"

#. Translators: commandline placeholder
#: gio/gapplication-tool.c:76 gio/glib-compile-resources.c:831 gio/glib-compile-resources.c:837 gio/glib-compile-resources.c:867 gio/gresource-tool.c:504
#: gio/gresource-tool.c:570 girepository/compiler/compiler.c:148 girepository/compiler/compiler.c:149 girepository/compiler/compiler.c:168
#: girepository/decompiler/decompiler.c:52 girepository/decompiler/decompiler.c:65
msgid "FILE"
msgstr "ไฟล์"

#: gio/gapplication-tool.c:76
msgid "Optional relative or absolute filenames, or URIs to open"
msgstr "ชื่อไฟล์แบบสัมพัทธ์หรือพาธเต็ม หรือ URI ที่จะเปิด (มีหรือไม่ก็ได้)"

#: gio/gapplication-tool.c:77
msgid "ACTION"
msgstr "การกระทำ"

#: gio/gapplication-tool.c:77
msgid "The action name to invoke"
msgstr "การกระทำที่จะเรียก"

#: gio/gapplication-tool.c:78
msgid "PARAMETER"
msgstr "พารามิเตอร์"

#: gio/gapplication-tool.c:78
msgid "Optional parameter to the action invocation, in GVariant format"
msgstr "พารามิเตอร์ของการเรียกการกระทำ ในรูปแบบ GVariant (มีหรือไม่ก็ได้)"

#: gio/gapplication-tool.c:100 gio/gresource-tool.c:535 gio/gsettings-tool.c:685
#, c-format
msgid ""
"Unknown command %s\n"
"\n"
msgstr ""
"ไม่รู้จักคำสั่ง %s\n"
"\n"

#: gio/gapplication-tool.c:105
msgid "Usage:\n"
msgstr "วิธีใช้:\n"

#: gio/gapplication-tool.c:118 gio/gresource-tool.c:560 gio/gsettings-tool.c:720
msgid "Arguments:\n"
msgstr "อาร์กิวเมนต์:\n"

#: gio/gapplication-tool.c:137 gio/gio-tool.c:259
msgid "[ARGS…]"
msgstr "[ARGS…]"

#: gio/gapplication-tool.c:138
#, c-format
msgid "Commands:\n"
msgstr "คำสั่ง:\n"

#. Translators: do not translate 'help', but please translate 'COMMAND'.
#: gio/gapplication-tool.c:150
#, c-format
msgid ""
"Use “%s help COMMAND” to get detailed help.\n"
"\n"
msgstr ""
"สั่ง “%s help COMMAND” เพื่อดูรายละเอียดวิธีใช้\n"
"\n"

#: gio/gapplication-tool.c:169
#, c-format
msgid ""
"%s command requires an application id to directly follow\n"
"\n"
msgstr ""
"คำสั่ง %s ต้องตามด้วย ID ของแอปพลิเคชันทันที\n"
"\n"

#: gio/gapplication-tool.c:175
#, c-format
msgid "invalid application id: “%s”\n"
msgstr "ID ของแอปพลิเคชันไม่ถูกต้อง: “%s”\n"

#. Translators: %s is replaced with a command name like 'list-actions'
#: gio/gapplication-tool.c:186
#, c-format
msgid ""
"“%s” takes no arguments\n"
"\n"
msgstr ""
"“%s” ไม่ต้องการอาร์กิวเมนต์\n"
"\n"

#: gio/gapplication-tool.c:270
#, c-format
msgid "unable to connect to D-Bus: %s\n"
msgstr "ไม่สามารถเชื่อมต่อกับ D-Bus: %s\n"

#: gio/gapplication-tool.c:290
#, c-format
msgid "error sending %s message to application: %s\n"
msgstr "เกิดข้อผิดพลาดขณะส่งข้อความ %s ไปยังแอปพลิเคชัน: %s\n"

#: gio/gapplication-tool.c:324
#, c-format
msgid "action name must be given after application id\n"
msgstr "ต้องมีชื่อการกระทำตามหลัง ID ของแอปพลิเคชัน\n"

#: gio/gapplication-tool.c:332
#, c-format
msgid ""
"invalid action name: “%s”\n"
"action names must consist of only alphanumerics, “-” and “.”\n"
msgstr ""
"ชื่อการกระทำไม่ถูกต้อง: “%s”\n"
"ชื่อการกระทำต้องประกอบด้วยตัวอักษร, ตัวเลข, “-” และ “.” เท่านั้น\n"

#: gio/gapplication-tool.c:351
#, c-format
msgid "error parsing action parameter: %s\n"
msgstr "เกิดข้อผิดพลาดขณะแจงพารามิเตอร์ของการกระทำ: %s\n"

#: gio/gapplication-tool.c:363
#, c-format
msgid "actions accept a maximum of one parameter\n"
msgstr "การกระทำรับพารามิเตอร์ไม่เกินหนึ่งตัว\n"

#: gio/gapplication-tool.c:418
#, c-format
msgid "list-actions command takes only the application id"
msgstr "คำสั่ง list-actions รับเพียง ID ของแอปพลิเคชันเท่านั้น"

#: gio/gapplication-tool.c:428
#, c-format
msgid "unable to find desktop file for application %s\n"
msgstr "หาไฟล์เดสก์ท็อปสำหรับโปรแกรม %s ไม่พบ\n"

#: gio/gapplication-tool.c:473
#, c-format
msgid ""
"unrecognized command: %s\n"
"\n"
msgstr ""
"พบคำสั่งที่ไม่รู้จัก: %s\n"
"\n"

#: gio/gbufferedinputstream.c:422 gio/gbufferedinputstream.c:500 gio/ginputstream.c:181 gio/ginputstream.c:381 gio/ginputstream.c:651 gio/ginputstream.c:1056
#: gio/goutputstream.c:227 gio/goutputstream.c:1052 gio/gpollableinputstream.c:217 gio/gpollableoutputstream.c:289
#, c-format
msgid "Too large count value passed to %s"
msgstr "มีการส่งค่า count ที่สูงเกินไปมาให้ %s"

#: gio/gbufferedinputstream.c:894 gio/gbufferedoutputstream.c:579 gio/gdataoutputstream.c:557
msgid "Seek not supported on base stream"
msgstr "สตรีมฐานไม่รองรับการเลื่อนตำแหน่งอ่านเขียน"

#: gio/gbufferedinputstream.c:941
msgid "Cannot truncate GBufferedInputStream"
msgstr "ไม่สามารถตัดท้าย GBufferedInputStream ทิ้ง"

#: gio/gbufferedinputstream.c:986 gio/ginputstream.c:1246 gio/giostream.c:317 gio/goutputstream.c:2208
msgid "Stream is already closed"
msgstr "สตรีมถูกปิดไปแล้ว"

#: gio/gbufferedoutputstream.c:616 gio/gdataoutputstream.c:587
msgid "Truncate not supported on base stream"
msgstr "สตรีมฐานไม่รองรับการตัดท้ายทิ้ง"

#: gio/gcancellable.c:327 gio/gdbusconnection.c:2009 gio/gdbusprivate.c:1434 gio/gsimpleasyncresult.c:871 gio/gsimpleasyncresult.c:897
#, c-format
msgid "Operation was cancelled"
msgstr "การกระทำถูกยกเลิก"

#: gio/gcharsetconverter.c:272
msgid "Invalid object, not initialized"
msgstr "อ็อบเจกต์ผิดพลาด ยังไม่ได้ตั้งค่าเริ่มต้น"

#: gio/gcharsetconverter.c:293 gio/gcharsetconverter.c:324
msgid "Incomplete multibyte sequence in input"
msgstr "มีลำดับไบต์ที่ไม่สมบูรณ์ในข้อมูลเข้า"

#: gio/gcharsetconverter.c:330 gio/gcharsetconverter.c:339
msgid "Not enough space in destination"
msgstr "มีที่ว่างไม่พอที่ปลายทาง"

#: gio/gcharsetconverter.c:357 gio/gdatainputstream.c:842 gio/gdatainputstream.c:1276 glib/gconvert.c:358 glib/gconvert.c:790 glib/giochannel.c:1571
#: glib/giochannel.c:1613 glib/giochannel.c:2474 glib/gutf8.c:966 glib/gutf8.c:1423
msgid "Invalid byte sequence in conversion input"
msgstr "มีลำดับไบต์ที่ไม่ถูกต้องในข้อมูลที่ป้อนให้ตัวแปลงรหัส"

#: gio/gcharsetconverter.c:362 glib/gconvert.c:366 glib/gconvert.c:704 glib/giochannel.c:1578 glib/giochannel.c:2489
#, c-format
msgid "Error during conversion: %s"
msgstr "เกิดข้อผิดพลาดระหว่างแปลงรหัส: %s"

#: gio/gcharsetconverter.c:460 gio/gsocket.c:1217
msgid "Cancellable initialization not supported"
msgstr "ไม่รองรับการตั้งค่าเริ่มต้นแบบยกเลิกได้"

#: gio/gcharsetconverter.c:471 glib/gconvert.c:231 glib/giochannel.c:1399
#, c-format
msgid "Conversion from character set “%s” to “%s” is not supported"
msgstr "ไม่รองรับการแปลงรหัสอักขระจาก “%s” ไปเป็น “%s”"

#: gio/gcharsetconverter.c:475 glib/gconvert.c:235
#, c-format
msgid "Could not open converter from “%s” to “%s”"
msgstr "ไม่สามารถเปิดตัวแปลงรหัสอักขระจาก “%s” ไปเป็น “%s” ได้"

#: gio/gcontenttype-fdo.c:368
#, c-format
msgid "%s type"
msgstr "ชนิด %s"

#: gio/gcontenttype-win32.c:199
msgid "Unknown type"
msgstr "ชนิดข้อมูลไม่รู้จัก"

#: gio/gcontenttype-win32.c:201
#, c-format
msgid "%s filetype"
msgstr "ชนิดไฟล์ %s"

#: gio/gconverteroutputstream.c:427
msgid "Unexpected data after end of conversion"
msgstr "มีข้อมูลที่ไม่คาดหมายหลังสิ้นสุดการแปลงรหัส"

#: gio/gcredentials.c:327
msgid "GCredentials contains invalid data"
msgstr "GCredentials มีข้อมูลที่ไม่ถูกต้อง"

#: gio/gcredentials.c:387 gio/gcredentials.c:682
msgid "GCredentials is not implemented on this OS"
msgstr "ยังไม่รองรับ GCredentials ในระบบปฏิบัติการนี้"

#: gio/gcredentials.c:546 gio/gcredentials.c:564
msgid "There is no GCredentials support for your platform"
msgstr "ไม่รองรับ GCredentials สำหรับแพลตฟอร์มของคุณ"

#: gio/gcredentials.c:622
msgid "GCredentials does not contain a process ID on this OS"
msgstr "GCredentials ไม่มีข้อมูล ID ของโปรเซสในระบบปฏิบัติการนี้"

#: gio/gcredentials.c:676
msgid "Credentials spoofing is not possible on this OS"
msgstr "ไม่สามารถปลอมแปลงข้อมูลลับในระบบปฏิบัติการนี้ได้"

#: gio/gdatainputstream.c:298
msgid "Unexpected early end-of-stream"
msgstr "พบจุดจบสตรีมก่อนกำหนด"

#: gio/gdbusaddress.c:159 gio/gdbusaddress.c:231 gio/gdbusaddress.c:318
#, c-format
msgid "Unsupported key “%s” in address entry “%s”"
msgstr "ไม่รองรับคีย์ “%s” ในรายการที่อยู่ “%s”"

#: gio/gdbusaddress.c:172
#, c-format
msgid "Meaningless key/value pair combination in address entry “%s”"
msgstr "คู่คีย์/ค่าไม่มีความหมายในรายการที่อยู่ “%s”"

#: gio/gdbusaddress.c:181
#, c-format
msgid "Address “%s” is invalid (need exactly one of path, dir, tmpdir, or abstract keys)"
msgstr "ที่อยู่ “%s” ไม่ถูกต้อง (ต้องมีคีย์ path, tmpdir หรือ abstract ดัวใดตัวหนึ่ง)"

#: gio/gdbusaddress.c:246 gio/gdbusaddress.c:257 gio/gdbusaddress.c:272 gio/gdbusaddress.c:333 gio/gdbusaddress.c:344
#, c-format
msgid "Error in address “%s” — the “%s” attribute is malformed"
msgstr "พบข้อผิดพลาดในที่อยู่ '%s' - แอตทริบิวต์ “%s” ผิดรูปแบบ"

#: gio/gdbusaddress.c:414 gio/gdbusaddress.c:679
#, c-format
msgid "Unknown or unsupported transport “%s” for address “%s”"
msgstr "ไม่รู้จักหรือไม่รองรับช่องขนส่ง “%s” สำหรับที่อยู่ “%s”"

#: gio/gdbusaddress.c:458
#, c-format
msgid "Address element “%s” does not contain a colon (:)"
msgstr "อิลิเมนต์ที่อยู่ “%s” ไม่มีทวิภาค (:)"

#: gio/gdbusaddress.c:467
#, c-format
msgid "Transport name in address element “%s” must not be empty"
msgstr "ชื่อช่องขนส่งในอิลิเมนต์ที่อยู่ “%s” ต้องไม่ว่างเปล่า"

#: gio/gdbusaddress.c:488
#, c-format
msgid "Key/Value pair %d, “%s”, in address element “%s” does not contain an equal sign"
msgstr "คู่คีย์/ค่าที่ %d (“%s”) ในอิลิเมนต์ที่อยู่ “%s” ไม่มีเครื่องหมายเท่ากับ"

#: gio/gdbusaddress.c:499
#, c-format
msgid "Key/Value pair %d, “%s”, in address element “%s” must not have an empty key"
msgstr "คู่คีย์/ค่าที่ %d (“%s”) ในอิลิเมนต์ที่อยู่ “%s” ต้องไม่มีคีย์เปล่า"

#: gio/gdbusaddress.c:513
#, c-format
msgid "Error unescaping key or value in Key/Value pair %d, “%s”, in address element “%s”"
msgstr "เกิดข้อผิดพลาดขณะถอดรหัสหลีกของคีย์หรือค่าในคู่คีย์/ค่าที่ %d (“%s”) ในอิลิเมนต์ที่อยู่ “%s”"

#: gio/gdbusaddress.c:581
#, c-format
msgid "Error in address “%s” — the unix transport requires exactly one of the keys “path” or “abstract” to be set"
msgstr "พบข้อผิดพลาดในที่อยู่ “%s” — ช่องขนส่งของ Unix ต้องมีการกำหนดคีย์ “path” หรือ “abstract” ตัวใดตัวหนึ่ง"

#. Translators: The first placeholder is a D-Bus connection address,
#. * the second is the literal name of an attribute in the address.
#.
#: gio/gdbusaddress.c:619 gio/gdbusaddress.c:634 gio/gdbusaddress.c:649
#, c-format
msgid "Error in address “%s” — the %s attribute is missing or malformed"
msgstr "พบข้อผิดพลาดในที่อยู่ “%s” - แอตทริบิวต์ %s ขาดหายไปหรือผิดรูปแบบ"

#: gio/gdbusaddress.c:671
msgid "Error auto-launching: "
msgstr "เกิดข้อผิดพลาดขณะเรียกทำงานอัตโนมัติ: "

#: gio/gdbusaddress.c:724
#, c-format
msgid "Error opening nonce file “%s”: %s"
msgstr "เกิดข้อผิดพลาดขณะเปิดไฟล์เฉพาะกาล “%s”: %s"

#: gio/gdbusaddress.c:743
#, c-format
msgid "Error reading from nonce file “%s”: %s"
msgstr "เกิดข้อผิดพลาดขณะอ่านไฟล์เฉพาะกาล “%s”: %s"

