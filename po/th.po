msgid "Key file contains key “%s” which has a value that cannot be interpreted."
msgstr "ไฟล์คีย์มีคีย์ “%s” ซึ่งมีค่าที่ไม่สามารถตีความได้"

#: glib/gkeyfile.c:2801 glib/gkeyfile.c:3175
#, c-format
msgid "Key file contains key “%s” in group “%s” which has a value that cannot be interpreted."
msgstr "ไฟล์คีย์มีคีย์ “%s” ในกลุ่ม “%s” ซึ่งมีค่าที่ไม่สามารถตีความได้"

#: glib/gkeyfile.c:2882 glib/gkeyfile.c:2962
#, c-format
msgid "Key “%s” in group “%s” has value “%s” where %s was expected"
msgstr "คีย์ “%s” ในกลุ่ม “%s” มีค่า “%s” แต่ต้องการค่า %s"

#: glib/gkeyfile.c:4412
msgid "Key file contains escape character at end of line"
msgstr "ไฟล์คีย์มีอักขระหลีกที่ท้ายบรรทัด"

#: glib/gkeyfile.c:4434
#, c-format
msgid "Key file contains invalid escape sequence “%s”"
msgstr "ไฟล์คีย์มีลำดับหลีก “%s” ที่ไม่ถูกต้อง"

#: glib/gkeyfile.c:4586
#, c-format
msgid "Value “%s” cannot be interpreted as a number."
msgstr "ค่า “%s” ไม่สามารถตีความเป็นตัวเลขได้"

#: glib/gkeyfile.c:4600
#, c-format
msgid "Integer value “%s” out of range"
msgstr "ค่าจำนวนเต็ม “%s” ออกนอกช่วง"

#: glib/gkeyfile.c:4633
#, c-format
msgid "Value “%s” cannot be interpreted as a float number."
msgstr "ค่า “%s” ไม่สามารถตีความเป็นตัวเลข float ได้"

#: glib/gkeyfile.c:4672
#, c-format
msgid "Value “%s” cannot be interpreted as a boolean."
msgstr "ค่า “%s” ไม่สามารถตีความเป็นบูลีนได้"

#: glib/gmappedfile.c:137
#, c-format
msgid "Failed to get attributes of file “%s%s%s%s”: fstat() failed: %s"
msgstr "อ่านแอตทริบิวต์ของไฟล์ “%s%s%s%s” ไม่สำเร็จ: fstat() ล้มเหลว: %s"

#: glib/gmappedfile.c:213
#, c-format
msgid "Failed to map %s%s%s%s: mmap() failed: %s"
msgstr "แม็ปไฟล์ '%s%s%s%s' ไม่สำเร็จ: mmap() ล้มเหลว: %s"

#: glib/gmappedfile.c:283
#, c-format
msgid "Failed to open file “%s”: open() failed: %s"
msgstr "เปิดไฟล์ “%s” ไม่สำเร็จ: open() ล้มเหลว: %s"

#: glib/gmarkup.c:354 glib/gmarkup.c:396
#, c-format
msgid "Error on line %d char %d: "
msgstr "มีข้อผิดพลาดที่บรรทัด %d อักขระที่ %d: "

#: glib/gmarkup.c:418 glib/gmarkup.c:501
#, c-format
msgid "Invalid UTF-8 encoded text in name — not valid “%s”"
msgstr "พบข้อความลงรหัส UTF-8 ไม่ถูกต้องในชื่อ — ข้อความที่ผิด: “%s”"

#: glib/gmarkup.c:429
#, c-format
msgid "“%s” is not a valid name"
msgstr "“%s” ไม่ใช่ชื่อที่ถูกต้อง"

#: glib/gmarkup.c:445
#, c-format
msgid "“%s” is not a valid name: “%c”"
msgstr "“%s” ไม่ใช่ชื่อที่ถูกต้อง: “%c”"

#: glib/gmarkup.c:569
#, c-format
msgid "Error on line %d: %s"
msgstr "มีข้อผิดพลาดที่บรรทัด %d: %s"

#: glib/gmarkup.c:646
#, c-format
msgid "Failed to parse “%-.*s”, which should have been a digit inside a character reference (&#234; for example) — perhaps the digit is too large"
msgstr "ไม่สามารถแจง “%-.*s” ซึ่งควรจะเป็นตัวเลขภายในตัวอ้างอิงอักขระ (เช่น &#234;) เป็นไปได้ว่าตัวเลขอาจจะมากเกินไป"

#: glib/gmarkup.c:658
msgid ""
"Character reference did not end with a semicolon; most likely you used an ampersand character without intending to start an entity — escape ampersand as &amp;"
msgstr "ตัวอ้างอิงอักขระไม่ได้ปิดด้วยอัฒภาค เป็นไปได้สูงที่คุณอาจใช้ ampersand โดยไม่ได้จงใจให้เริ่มเอนทิตี ถ้าใช่ ก็จงหลีก ampersand โดยแทนด้วย &amp; เสีย"

#: glib/gmarkup.c:684
#, c-format
msgid "Character reference “%-.*s” does not encode a permitted character"
msgstr "ตัวอ้างอิงอักขระ “%-.*s” ไม่ได้ลงรหัสอักขระที่อนุญาตให้ใช้ได้"

#: glib/gmarkup.c:722
msgid "Empty entity “&;” seen; valid entities are: &amp; &quot; &lt; &gt; &apos;"
msgstr "พบเอนทิตีว่างเปล่า “&;” ซึ่งไม่ถูกต้อง ค่าที่ใช้ได้คือ: &amp; &quot; &lt; &gt; &apos;"

#: glib/gmarkup.c:730
#, c-format
msgid "Entity name “%-.*s” is not known"
msgstr "ไม่รู้จักเอนทิตีชื่อ “%-.*s”"

#: glib/gmarkup.c:735
msgid "Entity did not end with a semicolon; most likely you used an ampersand character without intending to start an entity — escape ampersand as &amp;"
msgstr "เอนทิตีไม่ได้ปิดด้วยอัฒภาค เป็นไปได้สูงที่คุณอาจใช้ ampersand โดยไม่ได้จงใจให้เริ่มเอนทิตี ถ้าใช่ ก็จงหลีก ampersand โดยแทนด้วย &amp; เสีย"

#: glib/gmarkup.c:1153
msgid "Document must begin with an element (e.g. <book>)"
msgstr "เอกสารต้องเริ่มด้วยอิลิเมนต์ (เช่น <book>)"

#: glib/gmarkup.c:1197
#, c-format
msgid "“%s” is not a valid character following a “<” character; it may not begin an element name"
msgstr "“%s” ไม่ใช่อักขระที่ใช้ตามหลัง “<” ได้ จึงไม่สามารถใช้ขึ้นต้นชื่ออิลิเมนต์ได้"

#: glib/gmarkup.c:1240
#, c-format
msgid "Odd character “%s”, expected a “>” character to end the empty-element tag “%s”"
msgstr "พบอักขระแปลกปลอม “%s” ในขณะที่มองหาอักขระ “>” ที่จะมาปิดแท็กอิลิเมนต์เปล่า “%s”"

#: glib/gmarkup.c:1310
#, c-format
msgid "Too many attributes in element “%s”"
msgstr "มีแอตทริบิวต์มากเกินไปในอิลิเมนต์ “%s”"

#: glib/gmarkup.c:1330
#, c-format
msgid "Odd character “%s”, expected a “=” after attribute name “%s” of element “%s”"
msgstr "พบอักขระแปลกปลอม “%s” ในขณะที่กำลังมองหา “=” หลังชื่อแอตทริบิวต์ “%s” ของอิลิเมนต์ “%s”"

#: glib/gmarkup.c:1372
#, c-format
msgid ""
"Odd character “%s”, expected a “>” or “/” character to end the start tag of element “%s”, or optionally an attribute; perhaps you used an invalid character in "
"an attribute name"
msgstr "พบอักขระแปลกปลอม “%s” ในขณะที่กำลังมองหา “>” หรือ “/” ที่จะมาปิดแท็กตั้งต้นของอิลิเมนต์ “%s” หรือไม่ก็เป็นแอตทริบิวต์ เป็นไปได้ว่าคุณกำลังใช้อักขระที่ใช้ไม่ได้ในชื่อแอตทริบิวต์"

#: glib/gmarkup.c:1417
#, c-format
msgid "Odd character “%s”, expected an open quote mark after the equals sign when giving value for attribute “%s” of element “%s”"
msgstr "พบอักขระแปลกปลอม “%s” ในขณะที่กำลังมองหาอัญประกาศเปิดหลัง “=” ในการกำหนดค่าให้กับแอตทริบิวต์ “%s” ของอิลิเมนต์ “%s”"

#: glib/gmarkup.c:1551
#, c-format
msgid "“%s” is not a valid character following the characters “</”; “%s” may not begin an element name"
msgstr "“%s” ไม่ใช่อักขระที่ตามหลัง “</” ได้ “%s” ไม่สามารถใช้ขึ้นต้นชื่ออิลิเมนต์ได้"

#: glib/gmarkup.c:1589
#, c-format
msgid "“%s” is not a valid character following the close element name “%s”; the allowed character is “>”"
msgstr "“%s” ไม่ใช่อักขระที่ใช้ตามหลังชื่ออิลิเมนต์ “%s” ในแท็กปิดได้ อักขระเดียวที่อนุญาตคือ “>”"

#: glib/gmarkup.c:1601
#, c-format
msgid "Element “%s” was closed, no element is currently open"
msgstr "พบการปิดอิลิเมนต์ “%s” แต่ไม่มีอิลิเมนต์ใดเปิดอยู่"

#: glib/gmarkup.c:1610
#, c-format
msgid "Element “%s” was closed, but the currently open element is “%s”"
msgstr "พบการปิดอิลิเมนต์ “%s” แต่อิลิเมนต์ที่เปิดอยู่คือ “%s”"

#: glib/gmarkup.c:1763
msgid "Document was empty or contained only whitespace"
msgstr "เอกสารว่างเปล่า หรือมีแต่อักขระช่องว่าง"

#: glib/gmarkup.c:1777
msgid "Document ended unexpectedly just after an open angle bracket “<”"
msgstr "เอกสารจบแบบผิดปกติหลังจากวงเล็บแหลม “<”"

#: glib/gmarkup.c:1785 glib/gmarkup.c:1830
#, c-format
msgid "Document ended unexpectedly with elements still open — “%s” was the last element opened"
msgstr "เอกสารจบแบบผิดปกติ โดยยังมีอิลิเมนต์เปิดอยู่ — “%s” คืออิลิเมนต์ที่เปิดล่าสุด"

#: glib/gmarkup.c:1793
#, c-format
msgid "Document ended unexpectedly, expected to see a close angle bracket ending the tag <%s/>"
msgstr "เอกสารจบแบบผิดปกติ ในขณะที่กำลังมองหาวงเล็บแหลมที่จะมาปิดแท็ก <%s/>"

#: glib/gmarkup.c:1799
msgid "Document ended unexpectedly inside an element name"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางชื่ออิลิเมนต์"

#: glib/gmarkup.c:1805
msgid "Document ended unexpectedly inside an attribute name"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางชื่อแอตทริบิวต์"

#: glib/gmarkup.c:1810
msgid "Document ended unexpectedly inside an element-opening tag."
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางแท็กเปิดอิลิเมนต์"

#: glib/gmarkup.c:1816
msgid "Document ended unexpectedly after the equals sign following an attribute name; no attribute value"
msgstr "เอกสารจบแบบผิดปกติหลังจากเครื่องหมาย “=” หลังชื่อแอตทริบิวต์ โดยไม่มีค่าของแอตทริบิวต์"

#: glib/gmarkup.c:1823
msgid "Document ended unexpectedly while inside an attribute value"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางค่าแอตทริบิวต์"

#: glib/gmarkup.c:1840
#, c-format
msgid "Document ended unexpectedly inside the close tag for element “%s”"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางแท็กปิดสำหรับอิลิเมนต์ “%s”"

#: glib/gmarkup.c:1844
msgid "Document ended unexpectedly inside the close tag for an unopened element"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางแท็กปิดสำหรับอิลิเมนต์ที่ไม่ได้เปิด"

#: glib/gmarkup.c:1850
msgid "Document ended unexpectedly inside a comment or processing instruction"
msgstr "เอกสารจบแบบผิดปกติระหว่างกลางหมายเหตุหรือคำสั่งประมวลผล"

#: glib/goption.c:546 glib/goption.c:586
msgid "deprecated"
msgstr "เลิกใช้แล้ว"

#: glib/goption.c:727
msgid "[OPTION…]"
msgstr "[OPTION…]"

#: glib/goption.c:851
msgid "Help Options:"
msgstr "ตัวเลือกแสดงวิธีใช้:"

#: glib/goption.c:852
msgid "Show help options"
msgstr "แสดงวิธีใช้ตัวเลือกต่าง ๆ"

#: glib/goption.c:858
msgid "Show all help options"
msgstr "แสดงวิธีใช้ตัวเลือกต่าง ๆ ทั้งหมด"

#: glib/goption.c:921
msgid "Application Options:"
msgstr "ตัวเลือกของแอปพลิเคชัน:"

#: glib/goption.c:923
msgid "Options:"
msgstr "ตัวเลือก:"

#: glib/goption.c:987 glib/goption.c:1057
#, c-format
msgid "Cannot parse integer value “%s” for %s"
msgstr "ไม่สามารถแจงค่าจำนวนเต็ม “%s” สำหรับ %s"

#: glib/goption.c:997 glib/goption.c:1065
#, c-format
msgid "Integer value “%s” for %s out of range"
msgstr "ค่าจำนวนเต็ม “%s” สำหรับ %s ออกนอกช่วงที่กำหนด"

#: glib/goption.c:1022
#, c-format
msgid "Cannot parse double value “%s” for %s"
msgstr "ไม่สามารถแจงค่า double “%s” สำหรับ %s"

#: glib/goption.c:1030
#, c-format
msgid "Double value “%s” for %s out of range"
msgstr "ค่า double “%s” สำหรับ %s ออกนอกช่วงที่กำหนด"

#: glib/goption.c:1322 glib/goption.c:1401
#, c-format
msgid "Error parsing option %s"
msgstr "เกิดข้อผิดพลาดขณะแจงตัวเลือก: %s"

#: glib/goption.c:1423 glib/goption.c:1536
#, c-format
msgid "Missing argument for %s"
msgstr "ขาดอาร์กิวเมนต์สำหรับ %s"

#: glib/goption.c:2044
#, c-format
msgid "Unknown option %s"
msgstr "ไม่รู้จักตัวเลือก %s"

#: glib/gregex.c:561
msgid "corrupted object"
msgstr "อ็อบเจกต์เสียหาย"

#: glib/gregex.c:563
msgid "out of memory"
msgstr "หน่วยความจำเต็ม"

#: glib/gregex.c:578
msgid "internal error"
msgstr "ข้อผิดพลาดภายใน"

#: glib/gregex.c:580
msgid "the pattern contains items not supported for partial matching"
msgstr "แพตเทิร์นมีรายการที่ไม่รองรับในการจับคู่ทีละส่วน"

#: glib/gregex.c:582
msgid "back references as conditions are not supported for partial matching"
msgstr "ไม่รองรับการใช้การอ้างอิงย้อนกลับเป็นเงื่อนไขในการจับคู่ทีละส่วน"

#: glib/gregex.c:588
msgid "recursion limit reached"
msgstr "เกินขอบเขตการเรียกตัวเอง"

#: glib/gregex.c:590
msgid "bad offset"
msgstr "ออฟเซตไม่ถูกต้อง"

#: glib/gregex.c:592
msgid "recursion loop"
msgstr "เกิดวงวนเรียกตัวเอง"

#. should not happen in GRegex since we check modes before each match
#: glib/gregex.c:595
msgid "matching mode is requested that was not compiled for JIT"
msgstr "ต้องการ matching mode ซึ่งไม่ได้คอมไพล์สำหรับ JIT"

#: glib/gregex.c:616 glib/gregex.c:2145
msgid "unknown error"
msgstr "ข้อผิดพลาดไม่ทราบสาเหตุ"

#: glib/gregex.c:637
msgid "\\ at end of pattern"
msgstr "พบ \\ ที่ท้ายแพตเทิร์น"

#: glib/gregex.c:641
msgid "\\c at end of pattern"
msgstr "พบ \\c ที่ท้ายแพตเทิร์น"

#: glib/gregex.c:646
msgid "unrecognized character following \\"
msgstr "พบอักขระที่ไม่รู้จักตามหลัง \\"

#: glib/gregex.c:650
msgid "numbers out of order in {} quantifier"
msgstr "ค่าตัวเลขผิดพลาดในตัวระบุปริมาณ {}"

#: glib/gregex.c:654
msgid "number too big in {} quantifier"
msgstr "ค่าตัวเลขสูงเกินไปในตัวระบุปริมาณ {}"

#: glib/gregex.c:658
msgid "missing terminating ] for character class"
msgstr "ไม่มี ] ปิดในคลาสอักขระ"

#: glib/gregex.c:662
msgid "invalid escape sequence in character class"
msgstr "มีลำดับอักขระหลีกที่ไม่ถูกต้องในคลาสอักขระ"

#: glib/gregex.c:666
msgid "range out of order in character class"
msgstr "ค่าช่วงผิดพลาดในคลาสอักขระ"

#: glib/gregex.c:671
msgid "nothing to repeat"
msgstr "ไม่มีสิ่งที่จะซ้ำ"

#: glib/gregex.c:675
msgid "unrecognized character after (? or (?-"
msgstr "พบอักขระที่ไม่รู้จักหลัง (? หรือ (?-"

#: glib/gregex.c:679
msgid "POSIX named classes are supported only within a class"
msgstr "ใช้ชื่อคลาสอักขระของ POSIX ได้ในคลาสเท่านั้น"

#: glib/gregex.c:683
msgid "POSIX collating elements are not supported"
msgstr "ไม่รองรับ collating element ของ POSIX"

#: glib/gregex.c:689
msgid "missing terminating )"
msgstr "ไม่มี ) ปิด"

#: glib/gregex.c:693
msgid "reference to non-existent subpattern"
msgstr "มีการอ้างถึงแพตเทิร์นย่อยที่ไม่มีอยู่"

#: glib/gregex.c:697
msgid "missing ) after comment"
msgstr "ไม่มี ) หลังหมายเหตุ"

#: glib/gregex.c:701
msgid "regular expression is too large"
msgstr "นิพจน์ปกติยาวเกินไป"

#: glib/gregex.c:705
msgid "malformed number or name after (?("
msgstr "ตัวเลขหรือชื่อผิดรูปแบบหลัง (?("

#: glib/gregex.c:709
msgid "lookbehind assertion is not fixed length"
msgstr "แพตเทิร์นตรวจค่าย้อนไม่ได้มีความยาวคงที่"

#: glib/gregex.c:713
msgid "conditional group contains more than two branches"
msgstr "กลุ่มเงื่อนไขมีทางเลือกที่เป็นไปได้มากกว่าสองทาง"

#: glib/gregex.c:717
msgid "assertion expected after (?("
msgstr "ต้องการแพตเทิร์นตรวจค่าหลัง (?("

#: glib/gregex.c:721
msgid "a numbered reference must not be zero"
msgstr "การอ้างอิงด้วยตัวเลขต้องไม่ใช่ศูนย์"

#: glib/gregex.c:725
msgid "unknown POSIX class name"
msgstr "พบชื่อคลาสของ POSIX ที่ไม่รู้จัก"

#: glib/gregex.c:730
msgid "character value in \\x{...} sequence is too large"
msgstr "ค่าอักขระในลำดับ \\x{...} มีค่าสูงเกินไป"

#: glib/gregex.c:734
msgid "\\C not allowed in lookbehind assertion"
msgstr "ใช้ \\C ในแพตเทิร์นตรวจค่าย้อนไม่ได้"

#: glib/gregex.c:738
msgid "missing terminator in subpattern name"
msgstr "ไม่มีตัวปิดในชื่อแพตเทิร์นย่อย"

#: glib/gregex.c:742
msgid "two named subpatterns have the same name"
