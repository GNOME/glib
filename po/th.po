#, c-format
msgid ""
"Usage:\n"
"  gresource %s%s%s %s\n"
"\n"
"%s\n"
"\n"
msgstr ""
"วิธีใช้:\n"
"  gresource %s%s%s %s\n"
"\n"
"%s\n"
"\n"

